# ─────────────────────────────────────────────
# Tattoo App — Environment Variables
# Copy this file to .env for local development
# Set these in Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────

# ── Database (Turso) ──────────────────────────
# Create a free database at https://turso.tech
# Then: turso db show <db-name> --url
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io

# turso db tokens create <db-name>
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── File Uploads (Vercel Blob) ─────────────────
# Auto-set by Vercel when you enable Blob Storage in your project.
# For local dev, leave unset — files save to /uploads instead.
BLOB_READ_WRITE_TOKEN=

# ── Optional ──────────────────────────────────
# Your deployed frontend URL (for CORS in production)
FRONTEND_URL=https://your-app.vercel.app
